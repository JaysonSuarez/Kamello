# ─────────────────────────────────────────────
# KAMELLO - Plantilla de Variables de Entorno
# Copia estos nombres a la configuración de Vercel
# ─────────────────────────────────────────────

# Entorno
NODE_ENV=production

# Supabase (Obtenlos en Settings -> API)
SUPABASE_URL=tu_url_de_supabase
SUPABASE_ANON_KEY=tu_anon_key
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key (SOLO PARA EL BACKEND)

# Vite (Frontend)
VITE_SUPABASE_URL=tu_url_de_supabase
VITE_SUPABASE_ANON_KEY=tu_anon_key

# Web Push Notifications (Generadas con web-push)
VAPID_PUBLIC_KEY=tu_llave_publica
VAPID_PRIVATE_KEY=tu_llave_privada
VITE_VAPID_PUBLIC_KEY=tu_llave_publica
